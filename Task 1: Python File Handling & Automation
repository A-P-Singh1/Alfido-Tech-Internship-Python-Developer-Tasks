# Function to create and write data into a CSV file
# ============================================================
def write_csv_file():
try:
filename = input("Enter CSV filename (example: students.csv): ")
# Opening CSV file in write mode
with open(filename, "w", newline="") as file:
writer = csv.writer(file)
# Writing heading row
writer.writerow(["ID", "Name", "Marks"])
# Number of records
n = int(input("Enter number of student records: "))
# Taking user input for records
for i in range(n):
sid = input("Enter Student ID: ")
name = input("Enter Student Name: ")
marks = input("Enter Student Marks: ")
writer.writerow([sid, name, marks])
print("CSV file created successfully.\n")
 except ValueError:
print("Invalid input. Please enter numeric values properly.\n")
except Exception as e:
print("Error while writing CSV file:", e)
# ============================================================
# Function to read CSV file
# ============================================================
def read_csv_file():
try:
filename = input("Enter CSV filename to read: ")
# Opening CSV file in read mode
with open(filename, "r") as file:
reader = csv.reader(file)
print("\nCSV File Data:")
for row in reader:
print(row)
print()
except FileNotFoundError:
print("Error: CSV file not found.\n")
except Exception as e:
print("Error while reading CSV file:", e)


def write_text_file():
try:
filename = input("Enter TXT filename (example: notes.txt): ")
# Taking user input for file content
content = input("Enter content to write into the file: ")
# Opening file in write mode
with open(filename, "w") as file:
file.write(content)
print("TXT file created and data written successfully.\n")
except Exception as e:
print("Error while writing TXT file:", e)
# ============================================================
# Function to read a TXT file
# ============================================================
def read_text_file():
try:
filename = input("Enter TXT filename to read: ")
# Opening file in read mode
with open(filename, "r") as file:
data = file.read()
print("\nFile Content:")
print(data)
print()
except FileNotFoundError:
print("Error: File does not exist.\n")
except Exception as e:
 print("Error while reading TXT file:", e)

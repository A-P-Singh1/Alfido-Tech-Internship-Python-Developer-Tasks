# Function to rename a file
# ============================================================
def rename_file():
try:
old_name = input("Enter current filename: ")
new_name = input("Enter new filename: ")
# Renaming file
os.rename(old_name, new_name)
print("File renamed successfully.\n")
except FileNotFoundError:
print("Error: File not found.\n")
 except Exception as e:
print("Error while renaming file:", e)
# ============================================================
# Function to move a file
# ============================================================
def move_file():
try:
source = input("Enter source filename/path: ")
destination = input("Enter destination folder/path: ")
# Moving file
shutil.move(source, destination)
print("File moved successfully.\n")
except FileNotFoundError:
print("Error: Source file not found.\n")
except Exception as e:
print("Error while moving file:", e)
# ============================================================
# Function to delete a file
# ============================================================
def delete_file():
try:
filename = input("Enter filename to delete: ")
# Deleting file
os.remove(filename)
print("File deleted successfully.\n")
except FileNotFoundError:
print("Error: File not found.\n")
except Exception as e:
print("Error while deleting file:", e)
